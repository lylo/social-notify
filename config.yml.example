# social-notify configuration
#
# Bluesky: Create app passwords at https://bsky.app/settings/app-passwords
# Mastodon: Generate an access token at https://<instance>/settings/applications
# SMTP: For Gmail, use an App Password from https://myaccount.google.com/apppasswords

bluesky_accounts:
  - handle: alice.bsky.social
    app_password: xxxx-xxxx-xxxx-xxxx
    label: Alice (Bluesky)
  # Add more accounts as needed:
  # - handle: bob.bsky.social
  #   app_password: xxxx-xxxx-xxxx-xxxx
  #   label: Bob (Bluesky)

mastodon_account:
  instance: mastodon.social
  access_token: your-token-here
  label: Alice (Mastodon)

smtp:
  server: smtp.gmail.com
  port: 587
  username: you@gmail.com
  password: your-gmail-app-password
  from: you@gmail.com
  to: you@gmail.com
